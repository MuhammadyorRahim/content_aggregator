# ─── RSSHub Twitter/X auth token ────────────────────────────────
# Copy this file to .env.rsshub and fill in the value.
#
# How to get your auth_token:
#   1. Log in to x.com (twitter.com) in Chrome
#   2. Open DevTools (F12) → Application tab → Cookies → https://x.com
#   3. Find the "auth_token" cookie and copy its value (~40 hex chars)
#
# This file is loaded by docker-compose.yml via env_file.
# Without this token, X/Twitter sources will NOT work.
TWITTER_AUTH_TOKEN=REPLACE_WITH_YOUR_AUTH_TOKEN
